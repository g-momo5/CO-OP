{
  "name": "coop2",
  "version": "1.0.12",
  "main": "main.js",
  "scripts": {
    "dev": "node scripts/run-electron.cjs",
    "start": "node scripts/run-electron.cjs",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "publish": "electron-builder --publish always"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Gas Station Management System",
  "repository": {
    "type": "git",
    "url": "https://github.com/g-momo5/CO-OP.git"
  },
  "build": {
    "appId": "com.coop2.gasstation",
    "productName": "CO-OP",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "identity": null,
      "category": "public.app-category.business",
      "icon": "assets/logo_cpc.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "files": [
      "**/*",
      "!**/*.md",
      "!test-*.js"
    ],
    "win": {
      "icon": "assets/logo_cpc.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "publisherName": "CO-OP Gas Station",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "differentialPackage": true
    },
    "linux": {
      "icon": "assets/logo_cpc.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office"
    },
    "publish": {
      "provider": "github",
      "owner": "g-momo5",
      "repo": "CO-OP"
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@electron/remote": "^2.1.3",
    "electron": "^33.2.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "chart.js": "^4.5.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.1.7",
    "file-saver": "^2.0.5",
    "jspdf": "^3.0.1",
    "pg": "^8.16.3"
  }
}
