{
  "buildCommand": null,
  "ignoreCommand": "if [ \"$VERCEL_GIT_COMMIT_REF\" = \"main\" ]; then exit 1; else exit 0; fi",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/",
      "destination": "/mobile/index.html"
    },
    {
      "source": "/m",
      "destination": "/mobile/index.html"
    },
    {
      "source": "/m/:path*",
      "destination": "/mobile/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/mobile-assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300"
        }
      ]
    }
  ]
}
